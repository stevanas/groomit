{
  "expo": {
    "name": "GR-oom It",
    "slug": "frontend",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "frontend",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": false,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.groomit.app",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Find pet shops and groomers near you"
      }
    },
    "android": {
      "package": "com.groomit.app",
      "versionCode": 122,
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyDbOvjjXogHbtLoD6BgRcsE7UW72mzVd-w"
        }
      },
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#E2683C"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-image.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#E2683C"
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Find pet shops and groomers near you"
        }
      ],
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-9770198187060268~9686529734",
          "iosAppId": "ca-app-pub-9770198187060268~9686529734"
        }
      ],
      "expo-iap"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}

{
  "expo": {
    "name": "PawFind",
    "slug": "frontend",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "frontend",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Find pet shops and groomers near you"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#E2683C"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-image.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#E2683C"
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Find pet shops and groomers near you"
        }
      ],
      "react-native-google-mobile-ads",
      "expo-iap"
    ],
    "experiments": {
      "typedRoutes": true
    }
  },
  "react-native-google-mobile-ads": {
    "android_app_id": "ca-app-pub-9770198187060268~96865297343",
    "ios_app_id": "ca-app-pub-9770198187060268~96865297343"
  }
}
